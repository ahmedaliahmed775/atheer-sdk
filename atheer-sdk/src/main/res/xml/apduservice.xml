<?xml version="1.0" encoding="utf-8"?>
<!--
    ملف إعداد خدمة APDU لـ HCE (محاكاة البطاقة المضيفة)
    يحدد هذا الملف أن التطبيق هو تطبيق دفع رسمي (Payment App)
-->
<host-apdu-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/atheer_hce_description"
    android:requireDeviceUnlock="true">

    <!-- تصنيف payment ضروري لظهور التطبيق في إعدادات Default Payment App -->
    <aid-group
        android:category="payment"
        android:description="@string/atheer_payment_description">

        <!-- معرف تطبيق الدفع الخاص بـ Atheer (AID) -->
        <aid-filter android:name="A000000003101001" />

        <!-- معرّفات عالمية قياسية لضمان استجابة أجهزة الـ POS -->
        <aid-filter android:name="A0000000031010" /> <!-- Visa -->
        <aid-filter android:name="A0000000041010" /> <!-- Mastercard -->

    </aid-group>

</host-apdu-service>
